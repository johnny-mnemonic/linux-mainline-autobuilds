From 1a7ecd30cf930fd4e1e883a9674ed648dbe76ece Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Sun, 21 Jun 2026 00:27:22 +0200
Subject: [PATCH 133/133] ixgb: replace deprecated and now removed strncpy with
 strscpy

See 7677f635bf800dc0dd684713c4578ad81f7ad0c3 for why the count argument is
not decreased by 1 like for the old use with the no longer existing
strncpy().
---
 drivers/net/ethernet/intel/ixgb/ixgb_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/ethernet/intel/ixgb/ixgb_main.c b/drivers/net/ethernet/intel/ixgb/ixgb_main.c
index 20010c06fa53..3d70eac2b41d 100644
--- a/drivers/net/ethernet/intel/ixgb/ixgb_main.c
+++ b/drivers/net/ethernet/intel/ixgb/ixgb_main.c
@@ -416,7 +416,7 @@ ixgb_probe(struct pci_dev *pdev, const struct pci_device_id *ent)
 	netdev->watchdog_timeo = 5 * HZ;
 	netif_napi_add(netdev, &adapter->napi, ixgb_clean);
 
-	strncpy(netdev->name, pci_name(pdev), sizeof(netdev->name) - 1);
+	strscpy(netdev->name, pci_name(pdev), sizeof(netdev->name));
 
 	adapter->bd_number = cards_found;
 	adapter->link_speed = 0;
-- 
2.25.1

