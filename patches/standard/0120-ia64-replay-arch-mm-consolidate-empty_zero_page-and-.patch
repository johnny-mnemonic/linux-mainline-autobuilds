From feba09fcb064bb88a831e83d836c282e7f1dfde8 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Fri, 17 Apr 2026 00:36:43 +0200
Subject: [PATCH 120/121] ia64: replay "arch, mm: consolidate empty_zero_page"
 and "mm: cache struct

page for empty_zero_page and return it from ZERO_PAGE()"

See 6215d9f4470fbb48245ffdfade821685e2728c65 and 26513781d1b3a1e8b4b576ed62751d604a69b374.

Co-developed-by: Tomas Glozar <tglozar@gmail.com>
---
 arch/ia64/include/asm/pgtable.h | 7 -------
 arch/ia64/kernel/head.S         | 5 -----
 arch/ia64/mm/init.c             | 5 +++++
 3 files changed, 5 insertions(+), 12 deletions(-)

diff --git a/arch/ia64/include/asm/pgtable.h b/arch/ia64/include/asm/pgtable.h
index a6a7ccab977e..e1fd3b5b7b49 100644
--- a/arch/ia64/include/asm/pgtable.h
+++ b/arch/ia64/include/asm/pgtable.h
@@ -438,13 +438,6 @@ static inline pte_t pte_swp_clear_exclusive(pte_t pte)
 	return pte;
 }
 
-/*
- * ZERO_PAGE is a global shared page that is always zero: used
- * for zero-mapped memory areas etc..
- */
-extern unsigned long empty_zero_page[PAGE_SIZE/sizeof(unsigned long)];
-#define ZERO_PAGE(vaddr)	(virt_to_page(ia64_imva(empty_zero_page)))
-
 /* We provide our own get_unmapped_area to cope with VA holes for userland */
 #define HAVE_ARCH_UNMAPPED_AREA
 
diff --git a/arch/ia64/kernel/head.S b/arch/ia64/kernel/head.S
index 5e9cb4c762df..3cd84c86ef89 100644
--- a/arch/ia64/kernel/head.S
+++ b/arch/ia64/kernel/head.S
@@ -168,11 +168,6 @@ RestRR:											\
 
 	__PAGE_ALIGNED_BSS
 
-	.global empty_zero_page
-EXPORT_SYMBOL_GPL(empty_zero_page)
-empty_zero_page:
-	.skip PAGE_SIZE
-
 	.global swapper_pg_dir
 swapper_pg_dir:
 	.skip PAGE_SIZE
diff --git a/arch/ia64/mm/init.c b/arch/ia64/mm/init.c
index f6e8f2de2ba4..9a6e389ab73f 100644
--- a/arch/ia64/mm/init.c
+++ b/arch/ia64/mm/init.c
@@ -208,6 +208,11 @@ free_initrd_mem (unsigned long start, unsigned long end)
 	}
 }
 
+void __init arch_setup_zero_pages(void)
+{
+    __zero_page = virt_to_page(ia64_imva(empty_zero_page));
+}
+
 /*
  * This installs a clean page in the kernel's page table.
  */
-- 
2.25.1

