From e40a71a53310e6aec21b01c58fad2564378dfc73 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Mon, 10 Feb 2025 10:37:07 +0100
Subject: [PATCH 057/133] Revert "selftests/mm: remove unnecessary ia64 code
 and comment"

Not exactly a revert of 2f4db2861013fcfb4be11d0dc176271ae566241c
anymore due to post-v7.1 commits:

* a93cbee5275104d51d30a7d392d10fae2b58bfc0
* 9c5a65f374f86ed7105f064c89f74de8eb0c5f2f

...that need to be taken into account now, too.

This reverts commit 2f4db2861013fcfb4be11d0dc176271ae566241c.
---
 tools/testing/selftests/mm/Makefile          |  2 +-
 tools/testing/selftests/mm/hugetlb-mmap.c    | 20 ++++++++++++++++++--
 tools/testing/selftests/mm/hugetlb-shm.c     | 18 +++++++++++++++++-
 tools/testing/selftests/mm/hugetlb-vmemmap.c | 18 ++++++++++++++++--
 tools/testing/selftests/mm/run_vmtests.sh    |  2 +-
 5 files changed, 53 insertions(+), 7 deletions(-)

diff --git a/tools/testing/selftests/mm/Makefile b/tools/testing/selftests/mm/Makefile
index e6df968f0971..5b6ea1674c89 100644
--- a/tools/testing/selftests/mm/Makefile
+++ b/tools/testing/selftests/mm/Makefile
@@ -139,7 +139,7 @@ else ifeq ($(ARCH),powerpc)
 TEST_GEN_FILES += protection_keys
 endif
 
-ifneq (,$(filter $(ARCH),arm64 mips64 parisc64 powerpc riscv64 s390x sparc64 x86_64 s390))
+ifneq (,$(filter $(ARCH),arm64 ia64 mips64 parisc64 powerpc riscv64 s390x sparc64 x86_64 s390))
 TEST_GEN_FILES += va_high_addr_switch
 TEST_GEN_FILES += write_to_hugetlbfs
 endif
diff --git a/tools/testing/selftests/mm/hugetlb-mmap.c b/tools/testing/selftests/mm/hugetlb-mmap.c
index 0f2aad1b7dbd..47e96ee868b0 100644
--- a/tools/testing/selftests/mm/hugetlb-mmap.c
+++ b/tools/testing/selftests/mm/hugetlb-mmap.c
@@ -8,6 +8,13 @@
  * like /mnt) using the command mount -t hugetlbfs nodev /mnt. In this
  * example, the app is requesting memory of size 256MB that is backed by
  * huge pages.
+ *
+ * For the ia64 architecture, the Linux kernel reserves Region number 4 for
+ * huge pages.  That means that if one requires a fixed address, a huge page
+ * aligned address starting with 0x800000... will be required.  If a fixed
+ * address is not required, the kernel will select an address in the proper
+ * range.
+ * Other architectures, such as ppc64, i386 or x86_64 are not so constrained.
  */
 #define _GNU_SOURCE
 #include <stdlib.h>
@@ -23,6 +30,15 @@
 #define LENGTH (256UL*1024*1024)
 #define PROTECTION (PROT_READ | PROT_WRITE)
 
+/* Only ia64 requires this */
+#ifdef __ia64__
+#define ADDR (void *)(0x8000000000000000UL)
+#define FLAGS (MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB | MAP_FIXED)
+#else
+#define ADDR (void *)(0x0UL)
+#define FLAGS (MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB)
+#endif
+
 static void check_bytes(char *addr)
 {
 	ksft_print_msg("First hex is %x\n", *((unsigned int *)addr));
@@ -56,7 +72,7 @@ static void test_mmap(size_t length, int mmap_flags, int fd,
 	bool passed = true;
 	void *addr;
 
-	addr = mmap(NULL, length, PROTECTION, mmap_flags, fd, 0);
+	addr = mmap(ADDR, length, PROTECTION, mmap_flags, fd, 0);
 	if (addr == MAP_FAILED)
 		ksft_exit_fail_perror("mmap");
 
@@ -76,7 +92,7 @@ static void test_mmap(size_t length, int mmap_flags, int fd,
 static void test_anon_mmap(size_t length, int shift)
 {
 	const char *test_name = "hugetlb anonymous mmap";
-	int mmap_flags = MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB;
+	int mmap_flags = FLAGS;
 
 	if (shift)
 		mmap_flags |= (shift & MAP_HUGE_MASK) << MAP_HUGE_SHIFT;
diff --git a/tools/testing/selftests/mm/hugetlb-shm.c b/tools/testing/selftests/mm/hugetlb-shm.c
index 3ff7f062b7eb..de935c830c9a 100644
--- a/tools/testing/selftests/mm/hugetlb-shm.c
+++ b/tools/testing/selftests/mm/hugetlb-shm.c
@@ -8,6 +8,13 @@
  * SHM_HUGETLB in the shmget system call to inform the kernel that it is
  * requesting huge pages.
  *
+ * For the ia64 architecture, the Linux kernel reserves Region number 4 for
+ * huge pages.  That means that if one requires a fixed address, a huge page
+ * aligned address starting with 0x800000... will be required.  If a fixed
+ * address is not required, the kernel will select an address in the proper
+ * range.
+ * Other architectures, such as ppc64, i386 or x86_64 are not so constrained.
+ *
  * Note: The default shared memory limit is quite low on many kernels,
  * you may need to increase it via:
  *
@@ -50,6 +57,15 @@ static void prepare(void)
 	shm_limits_prepare(length);
 }
 
+/* Only ia64 requires this */
+#ifdef __ia64__
+#define ADDR (void *)(0x8000000000000000UL)
+#define SHMAT_FLAGS (SHM_RND)
+#else
+#define ADDR (void *)(0x0UL)
+#define SHMAT_FLAGS (0)
+#endif
+
 int main(void)
 {
 	int shmid;
@@ -67,7 +83,7 @@ int main(void)
 
 	ksft_print_msg("shmid: 0x%x\n", shmid);
 
-	shmaddr = shmat(shmid, NULL, 0);
+	shmaddr = shmat(shmid, ADDR, SHMAT_FLAGS);
 	if (shmaddr == (char *)-1) {
 		ksft_perror("Shared memory attach failure");
 		shmctl(shmid, IPC_RMID, NULL);
diff --git a/tools/testing/selftests/mm/hugetlb-vmemmap.c b/tools/testing/selftests/mm/hugetlb-vmemmap.c
index 507df78a158d..1a28a4f15510 100644
--- a/tools/testing/selftests/mm/hugetlb-vmemmap.c
+++ b/tools/testing/selftests/mm/hugetlb-vmemmap.c
@@ -23,6 +23,20 @@
 #define PM_PFRAME_BITS		55
 #define PM_PFRAME_MASK		~((1UL << PM_PFRAME_BITS) - 1)
 
+/*
+ * For ia64 architecture, Linux kernel reserves Region number 4 for hugepages.
+ * That means the addresses starting with 0x800000... will need to be
+ * specified.  Specifying a fixed address is not required on ppc64, i386
+ * or x86_64.
+ */
+#ifdef __ia64__
+#define MAP_ADDR		(void *)(0x8000000000000000UL)
+#define MAP_FLAGS		(MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB | MAP_FIXED)
+#else
+#define MAP_ADDR		NULL
+#define MAP_FLAGS		(MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB)
+#endif
+
 static size_t pagesize;
 static size_t maplength;
 
@@ -105,8 +119,8 @@ int main(int argc, char **argv)
 	if (!maplength)
 		ksft_exit_skip("Unable to determine huge page size\n");
 
-	addr = mmap(NULL, maplength, PROT_READ | PROT_WRITE,
-			MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB, -1, 0);
+	addr = mmap(MAP_ADDR, maplength, PROT_READ | PROT_WRITE,
+			MAP_FLAGS, -1, 0);
 	if (addr == MAP_FAILED)
 		ksft_exit_fail_perror("mmap");
 
diff --git a/tools/testing/selftests/mm/run_vmtests.sh b/tools/testing/selftests/mm/run_vmtests.sh
index 8c296dedf047..4f261712f1ee 100755
--- a/tools/testing/selftests/mm/run_vmtests.sh
+++ b/tools/testing/selftests/mm/run_vmtests.sh
@@ -155,7 +155,7 @@ run_gup_matrix() {
 }
 
 # filter 64bit architectures
-ARCH64STR="arm64 mips64 parisc64 ppc64 ppc64le riscv64 s390x sparc64 x86_64"
+ARCH64STR="arm64 ia64 mips64 parisc64 ppc64 ppc64le riscv64 s390x sparc64 x86_64"
 if [ -z "$ARCH" ]; then
 	ARCH=$(uname -m 2>/dev/null | sed -e 's/aarch64.*/arm64/')
 fi
-- 
2.25.1

