From 34339433c46d461dd121eecd5131776961e06466 Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Mon, 13 Apr 2026 18:55:48 +0200
Subject: [PATCH 120/133] ia64: Fix EFAULT in strnlen_user()

Commit 1b84d0eb72a1 ("ia64: Replace "braindead" strnlen_user() with
pipelined loop") added a pipelined implementation of strnlen_user()
that uses speculative ld1.s instructions that jump to the error path
directly when encountering NaT. This seems to cause spurious EFAULT
when not expected, for example, on exec.

Replace chk.s .Lexit with a proper NaT handler that re-loads the value
non-speculatively, resets the loop registers and jumps back to the loop
if the load succeeds.

Fixes: 1b84d0eb72a1 ("ia64: Replace "braindead" strnlen_user() with pipelined loop")
Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 arch/ia64/lib/strnlen_user.S | 18 ++++++++++++++++--
 1 file changed, 16 insertions(+), 2 deletions(-)

diff --git a/arch/ia64/lib/strnlen_user.S b/arch/ia64/lib/strnlen_user.S
index 85a934e8c803..7445940356e8 100644
--- a/arch/ia64/lib/strnlen_user.S
+++ b/arch/ia64/lib/strnlen_user.S
@@ -44,7 +44,7 @@ GLOBAL_ENTRY(__strnlen_user)
 	cmp.ne.and p6,p0=cnt2,cend
 (p6)	br.sptk .Loop2
 	;;
-	chk.s valx,.Lexit
+	chk.s valx,.Lfaultx
 	adds ret0=-1,cnt1
 	br.ret.sptk.many rp
 .balign 32
@@ -55,9 +55,23 @@ GLOBAL_ENTRY(__strnlen_user)
 	cmp.ne.and p6,p0=cnt1,cend
 (p6)	br.sptk .Loop1
 	;;
-	chk.s valy,.Lexit
+	chk.s valy,.Lfaulty
 	adds ret0=-1,cnt2
 	br.ret.sptk.many rp
+.Lfaultx:
+	adds cnt1=-2,cnt1
+	adds ptr=-2,ptr
+	cmp.eq p6,p0=r0,r0
+	;;
+	EXCLR(.Lexit, ld1 valx=[ptr],1)
+	br.sptk .Loop1
+.Lfaulty:
+	adds cnt2=-2,cnt2
+	adds ptr=-2,ptr
+	cmp.eq p6,p0=r0,r0
+	;;
+	EXCLR(.Lexit, ld1 valy=[ptr],1)
+	br.sptk .Loop2
 .Lexit:
 	mov ret0=0
 	br.ret.sptk.many rp
-- 
