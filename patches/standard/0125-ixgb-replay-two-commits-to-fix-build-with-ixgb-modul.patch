From dafcee9fc8e7e61c45602692fda42a5d3f013007 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Tue, 9 Jun 2026 14:10:17 +0200
Subject: [PATCH 125/136] ixgb: replay two commits to fix build with ixgb
 module

See:
* "timers: Rename del_timer_sync() to timer_delete_sync()"
  9b13df3fb64ee95e2397585404e442afee2c7d4f
* "treewide, timers: Rename from_timer() to timer_container_of()"
  41cb08555c4164996d67c78b3bf1c658075b75f1
---
 drivers/net/ethernet/intel/ixgb/ixgb_main.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/net/ethernet/intel/ixgb/ixgb_main.c b/drivers/net/ethernet/intel/ixgb/ixgb_main.c
index b4d47e7a76c8..20010c06fa53 100644
--- a/drivers/net/ethernet/intel/ixgb/ixgb_main.c
+++ b/drivers/net/ethernet/intel/ixgb/ixgb_main.c
@@ -261,7 +261,7 @@ ixgb_down(struct ixgb_adapter *adapter, bool kill_watchdog)
 		pci_disable_msi(adapter->pdev);
 
 	if (kill_watchdog)
-		del_timer_sync(&adapter->watchdog_timer);
+		timer_delete_sync(&adapter->watchdog_timer);
 
 	adapter->link_speed = 0;
 	adapter->link_duplex = 0;
@@ -1108,7 +1108,7 @@ ixgb_set_multi(struct net_device *netdev)
 static void
 ixgb_watchdog(struct timer_list *t)
 {
-	struct ixgb_adapter *adapter = from_timer(adapter, t, watchdog_timer);
+	struct ixgb_adapter *adapter = timer_container_of(adapter, t, watchdog_timer);
 	struct net_device *netdev = adapter->netdev;
 	struct ixgb_desc_ring *txdr = &adapter->tx_ring;
 
-- 
