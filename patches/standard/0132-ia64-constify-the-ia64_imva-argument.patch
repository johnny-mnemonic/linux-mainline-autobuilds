From 250d0acfd808d02ddc4f470f60006b9a6a325f41 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Sun, 21 Jun 2026 00:21:42 +0200
Subject: [PATCH 132/133] ia64: constify the ia64_imva() argument

warnings like the following are new after v7.1 and always relate to an
ia64_imva() argument with const qualifier. If the used ia64_imva()
arguments always point to a constant value anyways, we can also constify
this argument and avoid these warnings:
```
In file included from ./arch/ia64/include/asm/page.h:83,
                 from ./arch/ia64/include/asm/ptrace.h:46,
                 from ./arch/ia64/include/asm/processor.h:20,
                 from ./include/linux/sched.h:13,
                 from ./include/linux/ratelimit.h:6,
                 from ./include/linux/dev_printk.h:16,
                 from ./include/linux/device.h:15,
                 from ./include/linux/dma-mapping.h:5,
                 from ./include/linux/dma-map-ops.h:9,
                 from arch/ia64/mm/init.c:11:
arch/ia64/mm/init.c: In function 'arch_setup_zero_pages':
arch/ia64/mm/init.c:213:42: warning: passing argument 1 of 'ia64_imva' discards 'const' qualifier from pointer target type [-Wdiscarded-qualifiers]
  213 |     __zero_page = virt_to_page(ia64_imva(empty_zero_page));
      |                                          ^~~~~~~~~~~~~~~
./include/asm-generic/memory_model.h:46:45: note: in definition of macro '__pfn_to_page'
   46 | #define __pfn_to_page(pfn)      (vmemmap + (pfn))
      |                                             ^~~
./arch/ia64/include/asm/page.h:85:45: note: in expansion of macro '__pa'
   85 | #define virt_to_page(kaddr)     pfn_to_page(__pa(kaddr) >> PAGE_SHIFT)
      |                                             ^~~~
arch/ia64/mm/init.c:213:19: note: in expansion of macro 'virt_to_page'
  213 |     __zero_page = virt_to_page(ia64_imva(empty_zero_page));
      |                   ^~~~~~~~~~~~
./arch/ia64/include/asm/processor.h:628:18: note: expected 'void *' but argument is of type 'const uint8_t *' {aka 'const unsigned char *'}
  628 | ia64_imva (void *addr)
      |            ~~~~~~^~~~
```
---
 arch/ia64/include/asm/processor.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/ia64/include/asm/processor.h b/arch/ia64/include/asm/processor.h
index c75beb490c63..727b38279209 100644
--- a/arch/ia64/include/asm/processor.h
+++ b/arch/ia64/include/asm/processor.h
@@ -625,7 +625,7 @@ ia64_rotr (__u64 w, __u64 n)
  * in the region 7 identity mapped virtual area.
  */
 static inline void *
-ia64_imva (void *addr)
+ia64_imva (const void *addr)
 {
 	void *result;
 	result = (void *) ia64_tpa(addr);
-- 
2.25.1

