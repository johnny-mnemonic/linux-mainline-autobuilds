From 60dba787390b96c997bcf4f6971ddd8c4431c67d Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Thu, 16 Apr 2026 13:02:08 +0200
Subject: [PATCH 2/2] ia64: replay "mm: convert do_brk_flags() to use
 vma_flags_t"

See 3a6455d56bd7c4cfb1ea35ddae052943065e338e.
---
 arch/ia64/include/asm/page.h | 2 +-
 arch/ia64/mm/init.c          | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/ia64/include/asm/page.h b/arch/ia64/include/asm/page.h
index 2d37234f7f5b..abd342789ce5 100644
--- a/arch/ia64/include/asm/page.h
+++ b/arch/ia64/include/asm/page.h
@@ -169,7 +169,7 @@ extern unsigned int hpage_shift;
 
 #define PAGE_OFFSET			RGN_BASE(RGN_KERNEL)
 
-#define VM_DATA_DEFAULT_FLAGS	VM_DATA_FLAGS_TSK_EXEC
+#define VMA_DATA_DEFAULT_FLAGS	VMA_DATA_FLAGS_TSK_EXEC
 
 #define GATE_ADDR		RGN_BASE(RGN_GATE)
 
diff --git a/arch/ia64/mm/init.c b/arch/ia64/mm/init.c
index 57e5182c4761..a0f28f2ce81a 100644
--- a/arch/ia64/mm/init.c
+++ b/arch/ia64/mm/init.c
@@ -125,7 +125,7 @@ ia64_init_addr_space (void)
 		vma_set_anonymous(vma);
 		vma->vm_start = current->thread.rbs_bot & PAGE_MASK;
 		vma->vm_end = vma->vm_start + PAGE_SIZE;
-		vm_flags_init(vma, VM_DATA_DEFAULT_FLAGS|VM_GROWSUP|VM_ACCOUNT);
+		vm_flags_init(vma, vma_flags_to_legacy(VMA_DATA_DEFAULT_FLAGS)|VM_GROWSUP|VM_ACCOUNT);
 		vma->vm_page_prot = vm_get_page_prot(vma->vm_flags);
 		mmap_write_lock(current->mm);
 		if (insert_vm_struct(current->mm, vma)) {
-- 
