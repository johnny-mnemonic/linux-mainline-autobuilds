From f2ba8d556ce588c57bcab9d605a905a05e164ef0 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Tue, 16 Jun 2026 00:59:13 +0200
Subject: [PATCH] Partially revert "vdso/treewide: Drop GENERIC_TIME_VSYSCALL"

...needed to have GENERIC_TIME_VSYSCALL still.

See 96942092d5e67c71af246fa3bc1422cdf80a5dc9.
---
 kernel/time/Kconfig | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/kernel/time/Kconfig b/kernel/time/Kconfig
index 33bf9b6970cd..6a11964377e6 100644
--- a/kernel/time/Kconfig
+++ b/kernel/time/Kconfig
@@ -20,6 +20,10 @@ config ARCH_CLOCKSOURCE_INIT
 config ARCH_WANTS_CLOCKSOURCE_READ_INLINE
 	bool
 
+# Timekeeping vsyscall support
+config GENERIC_TIME_VSYSCALL
+	bool
+
 # The generic clock events infrastructure
 config GENERIC_CLOCKEVENTS
 	def_bool !LEGACY_TIMER_TICK
-- 
2.25.1

