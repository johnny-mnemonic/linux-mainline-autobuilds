From a548bc611dc01f28b2ffd63c97c28318fc4781dd Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Thu, 16 Apr 2026 21:16:26 +0200
Subject: [PATCH 1/2] ia64: make own empty_zero_page and ZERO_PAGE() effective

The "x86 definition of empty_zero_page and ZERO_PAGE()" used in the
core MM since 6215d9f4470fbb48245ffdfade821685e2728c65 don't seem to
work correctly with ia64, i.e. on rx2620 a kernel w/o this change
panics with:

```
[    3.481730] This architecture does not have kernel memory protection.
[    3.481947] Run /init as init process
[    3.481947]   with arguments:
[    3.481947]     /init
[    3.481947]   with environment:
[    3.489116]     HOME=/
[    3.489116]     TERM=linux
[    3.489116] Kernel panic - not syncing: Attempted to kill init! exitcode=0x0000000b
[    3.493116] ---[ end Kernel panic - not syncing: Attempted to kill init!
```

So let's use our vetted definitions instead, on the cost of small
modifications to generic code and the addition of an empty function
to ia64 specific code.

Also consider 26513781d1b3a1e8b4b576ed62751d604a69b374.
---
 arch/ia64/mm/init.c     | 5 +++++
 include/linux/pgtable.h | 2 ++
 mm/mm_init.c            | 6 +++---
 3 files changed, 10 insertions(+), 3 deletions(-)

diff --git a/arch/ia64/mm/init.c b/arch/ia64/mm/init.c
index f6e8f2de2ba4..57e5182c4761 100644
--- a/arch/ia64/mm/init.c
+++ b/arch/ia64/mm/init.c
@@ -43,6 +43,11 @@ extern void ia64_tlb_init (void);
 
 unsigned long MAX_DMA_ADDRESS = PAGE_OFFSET + 0x100000000UL;
 
+/*
+ * to satisfy init_zero_page_pfn() in mm/mm_init.c
+ */
+void __init arch_setup_zero_pages(void){};
+
 void
 __ia64_sync_icache_dcache (pte_t pte)
 {
diff --git a/include/linux/pgtable.h b/include/linux/pgtable.h
index 150dfa9cf634..7239d42d38f1 100644
--- a/include/linux/pgtable.h
+++ b/include/linux/pgtable.h
@@ -1995,6 +1995,7 @@ static inline unsigned long zero_pfn(unsigned long addr)
 	return zero_page_pfn;
 }
 
+#ifndef CONFIG_IA64
 extern uint8_t empty_zero_page[PAGE_SIZE];
 extern struct page *__zero_page;
 
@@ -2003,6 +2004,7 @@ static inline struct page *_zero_page(unsigned long addr)
 	return __zero_page;
 }
 #define ZERO_PAGE(vaddr) _zero_page(vaddr)
+#endif /* CONFIG_IA64 */
 
 #endif /* __HAVE_COLOR_ZERO_PAGE */
 
diff --git a/mm/mm_init.c b/mm/mm_init.c
index 9998396a7a70..c5eacf1bd257 100644
--- a/mm/mm_init.c
+++ b/mm/mm_init.c
@@ -56,13 +56,13 @@ EXPORT_SYMBOL(high_memory);
 unsigned long zero_page_pfn __ro_after_init;
 EXPORT_SYMBOL(zero_page_pfn);
 
-#ifndef __HAVE_COLOR_ZERO_PAGE
+#if !defined(__HAVE_COLOR_ZERO_PAGE) && !defined(CONFIG_IA64)
 uint8_t empty_zero_page[PAGE_SIZE] __page_aligned_bss;
 EXPORT_SYMBOL(empty_zero_page);
 
 struct page *__zero_page __ro_after_init;
 EXPORT_SYMBOL(__zero_page);
-#endif /* __HAVE_COLOR_ZERO_PAGE */
+#endif /* __HAVE_COLOR_ZERO_PAGE || CONFIG_IA64 */
 
 #ifdef CONFIG_DEBUG_MEMORY_INIT
 int __meminitdata mminit_loglevel;
@@ -2691,7 +2691,7 @@ static void __init mem_init_print_info(void)
 		);
 }
 
-#ifndef __HAVE_COLOR_ZERO_PAGE
+#if !defined(__HAVE_COLOR_ZERO_PAGE) && !defined(CONFIG_IA64)
 /*
  * architectures that __HAVE_COLOR_ZERO_PAGE must define this function
  */
-- 
